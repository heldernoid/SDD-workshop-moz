      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Educação dos pais",
      "forma_oral": "MHUNTI YI THLANGISA A ÑWANA.",
      "traducao_literal": "A gazela ensina a cria a brincar.",
      "sentido": "O exemplo dos pais é a melhor escola dos filhos. O que se aprende no berço sempre fica."
    },
    {
      "id": 211,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Educar para o futuro",
      "forma_oral": "A NSINYA VA WU WOLOLA NA WU RI WUTSONGO.",
      "traducao_literal": "Endireita-se a árvore enquanto é pequenina.",
      "sentido": "De pequenino se torce o pepino."
    },
    {
      "id": 212,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Prevalência do carácter",
      "forma_oral": "NCHILA WA MBYANA LOKO WU KHOTSEKILE A WU NA MUWOLOLI.",
      "traducao_literal": "Quando a cauda do cão é torta não há quem a endireite.",
      "sentido": "O que torto nasce, torto morre."
    },
    {
      "id": 213,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Quando a educação falha",
      "forma_oral": "NHEMHA YI PSWALA TOYA.",
      "traducao_literal": "De um herói pode nascer um covarde.",
      "sentido": "Muitas vezes os filhos são a vergonha dos pais."
    },
    {
      "id": 214,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Prevalência do carácter",
      "forma_oral": "ÑHWARI YI PSWALA A ÑHWARI.",
      "traducao_literal": "Uma perdiz dá uma perdiz.",
      "sentido": "Tal pai, tal filho."
    },
    {
      "id": 215,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Valor moral",
      "forma_oral": "A KU YAMBALA I MAVALA, KU VELEKA I WUKOSI.",
      "traducao_literal": "Vestir-se bem é só cores; riqueza é ter filhos.",
      "sentido": "De nada vale a beleza sem a virtude."
    },
    {
      "id": 216,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Aparências",
      "forma_oral": "KWAKWA RA SEKWA RI VONIWA KULE.",
      "traducao_literal": "Uma cuácua (fruto do mato) da cor do pato (madura) vê-se de longe (mas pode estar podre por dentro).",
      "sentido": "As aparências iludem. Não há beleza sem senão."
    },
    {
      "id": 217,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Aparências",
      "forma_oral": "U NGA TSHEMBI MUNHU HI NGOE.",
      "traducao_literal": "Não confies em ninguém pelo bom aspecto do rosto.",
      "sentido": "A gente vê caras e não vê corações."
    },
    {
      "id": 218,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Aparências",
      "forma_oral": "A KUWA RO PSHWUKA A RI PFUMALI SWIVUNGU A NDZENI.",
      "traducao_literal": "A um figo maduro não faltam bichos dentro.",
      "sentido": "Nem tudo o que luz é ouro, nem o que alveja é prata."
    },
    {
      "id": 219,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "O que tem valor",
      "forma_oral": "NDZHAKA YA BAVA DJANA WA HA HANYA.",
      "traducao_literal": "A herança paterna come-se enquanto o pai vive.",
      "sentido": "A melhor herança são os bons ensinamentos."
    },
    {
      "id": 220,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Pessoas",
      "forma_oral": "A MBITA YA VOVO YI DLAYA LE'TO TIYA.",
      "traducao_literal": "Uma panela fraca parte as panelas fortes.",
      "sentido": "Uma pessoa doente pode viver mais que uma pessoa sã."
    },
    {
      "id": 221,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Aparências",
      "forma_oral": "A NHLEKO A WU HLEKELI XAKA NTSENA.",
      "traducao_literal": "Não se ri só para o parente.",
      "sentido": "O rosto nem sempre mostra o que vai no coração."
    },
    {
      "id": 222,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Animais / Segredos",
      "forma_oral": "A HOMU A YI NGE PSWALELI NTLAMBHINI.",
      "traducao_literal": "A vaca não pare no meio da manada.",
      "sentido": "Há segredos que não se devem divulgar."
    },
    {
      "id": 223,
      "topic": "proverbios",
      "type": "proverbio",
      "tema": "Cuidado / Sabedoria",
      "forma_oral": "A NTAVA A VA YI KHWELI HI KU TSUTSUMA.",
      "traducao_literal": "Não se sobe a montanha a correr.",
      "sentido": "Mais vale jeito que força."
    },
